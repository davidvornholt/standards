{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["biome.jsonc", "biome.base.jsonc"],
  "tasks": {
    "standards": {
      "cache": false,
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "cache": false,
      "outputs": []
    },
    "check-types": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "test:a11y": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
