node_modules/
.turbo/
dist/
.next/
*.log

# Generated by `bun standards dev-env` from the encrypted secrets/dev.yaml;
# the command refuses to write env files git would track.
.env.local

# Claude agent worktrees are full parallel checkouts; they are never part of
# this repository's own tree (biome.jsonc force-ignores them from the scanner
# too).
.claude/worktrees/

# The standards repo is the authority for canonical files, so it does not run
# the drift `--check` against itself; its lock would only ever record its own
# hashes. Consumers commit their lock (it is their drift baseline); the source
# does not need one.
sync-standards.lock
