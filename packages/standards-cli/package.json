    "README.md",
    "SOURCE_COMMIT",
    "src/cli.ts",
    "src/github-api.ts",
    "src/github-apply.ts",
    "src/github-commands.ts",
    "src/github-diff.ts",
    "src/github-environment-apply.ts",
    "src/github-environment-settings.ts",
    "src/github-environments.ts",
    "src/github-settings.ts"
