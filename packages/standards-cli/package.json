{
  "name": "@davidvornholt/standards",
  "version": "0.1.0",
  "description": "Bootstrap, synchronize, and validate davidvornholt/standards consumers",
  "license": "MIT",
  "type": "module",
  "bin": {
    "standards": "src/cli.ts"
  },
  "files": [
